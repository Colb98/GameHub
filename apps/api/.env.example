# --- Core ---
PORT=4000
DATABASE_URL=postgresql://gamehub:gamehub@localhost:5433/gamehub
WEB_ORIGIN=http://localhost:3000
# Where uploaded game bundles are stored (served at /g in dev, by Caddy in prod)
GAMES_STORAGE_DIR=../../storage/games
# Set to "true" behind Caddy/Cloudflare so secure cookies work
COOKIE_SECURE=false

# --- Auth secrets (generate long random strings for production) ---
JWT_SECRET=dev-jwt-secret-change-me
JWT_GUEST_SECRET=dev-guest-secret-change-me

# --- Social login (leave empty to disable a provider) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Public URL of this API, used to build OAuth callback URLs
API_PUBLIC_URL=http://localhost:4000
